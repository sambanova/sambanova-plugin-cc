{
    "$schema": "https://opencode.ai/config.json",
    "model": "sambanova/{{ model.id }}",
    "instructions": [
        {% for rule in rule_files %}
        {{ rule | tojson }}{% if not loop.last %},{% endif %}
        {% endfor %}
    ],
    {% if external_dirs %}
    "permission": {
        "external_directory": {
            {% for d in external_dirs %}
            {{ (d ~ "/**") | tojson }}: "allow"{% if not loop.last %},{% endif %}
            {% endfor %}
        }
    },
    {% endif %}
    "provider": {
        "sambanova": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "SambaNova",
            "options": {
                "baseURL": "{{ base_url }}",
                "apiKey": "{env:SAMBANOVA_API_KEY}"
            },
            "models": {
                "{{ model.id }}": {
                    "name": "{{ model.id }}",
                    "temperature": true,
                    "limit": {
                        "context": {{ model.context_length }},
                        "output": {{ model.max_completion_tokens }}
                    }
                }
            }
        }
    },
    "agent": {
        {% for agent in ["plan", "explore", "build", "general"] %}
        "{{ agent }}": {
            {% for key, value in sampling_parameters.items() %}
            "{{ key }}": {{ value }}{% if not loop.last %},{% endif %}

            {% endfor %}
        }{% if not loop.last %},{% endif %}

        {% endfor %}
    }
}
