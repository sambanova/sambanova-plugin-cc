{
  "description": "sambanova-plugin-cc setup hook - initializes venv and agent_shims on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "source \"${CLAUDE_PLUGIN_ROOT}/hooks/setup.sh\" \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      }
    ]
  }
}
